{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/accessride",
      "destination": "https://accessride.vercel.app/index.html"
    },
    {
      "source": "/accessride/:path*",
      "destination": "https://accessride.vercel.app/:path*"
    }
  ]
}
